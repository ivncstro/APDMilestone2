<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #ecf0f1;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.AdminDiscountsController">
    <left>
        <HBox>
            <children>
                <VBox prefHeight="900.0" prefWidth="200.0" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 20 10 20 10;">
                    <children>
                        <Label text="Hotel Transilvania" textFill="white" wrapText="true">
                            <font>
                                <Font name="System Bold" size="16.0" />
                            </font>
                        </Label>
                        <Separator style="-fx-background-color: #7f8c8d;" />
                        <Button mnemonicParsing="false" onAction="#goToDashboard" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Dashboard">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#goToWaitlist" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Waitlist">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#goToLoyalty" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Loyalty Program">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#goToReports" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Reports">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#goToLog" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Activity Log">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                  <Button mnemonicParsing="false" onAction="#goToPayment" style="-fx-background-color: transparent; -fx-alignment: BASELINE_LEFT;" text="Payment" textFill="WHITE">
                     <font>
                        <Font size="15.0" />
                     </font>
                  </Button>
                  <Button mnemonicParsing="false" style="-fx-background-color: #e2b96f; -fx-alignment: BASELINE_LEFT;" text="Seasonal Discounts">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
                        <Button mnemonicParsing="false" onAction="#goToFeedback" style="-fx-background-color: transparent; -fx-text-fill: white; -fx-alignment: BASELINE_LEFT;" text="Feedback">
                     <font>
                        <Font size="15.0" />
                     </font></Button>
                  <Button mnemonicParsing="false" onAction="#logout" style="-fx-background-radius: 5; -fx-background-color: #16213e; -fx-border-color: #e2b96f; -fx-border-radius: 10;" text="Logout" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                     <VBox.margin>
                        <Insets left="60.0" top="430.0" />
                     </VBox.margin>
                  </Button>
                    </children>
                    <padding>
                        <Insets top="20.0" />
                    </padding>
                </VBox>
            <Separator prefHeight="915.0" prefWidth="0.0" style="-fx-background-color: #e2b96f;">
               <padding>
                  <Insets right="-7.0" />
               </padding>
            </Separator>
            </children>
        </HBox>
    </left>
    <center>
        <VBox spacing="20.0" style="-fx-background-color: #1a1a2e; -fx-padding: 20;">
            <children>
                <Label text="Admin Dashboard • Seasonal Discount Management" textFill="#e2b96f">
                    <font>
                        <Font name="System Bold" size="24.0" />
                    </font>
                </Label>
                <Separator style="-fx-background-color: #e2b96f; -fx-pref-height: 1; -fx-max-width: Infinity;" />
                <VBox spacing="20.0" style="-fx-background-color: #16213e; -fx-background-radius: 8; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.05), 5, 0, 0, 2);">
                    <children>
                        <Label text="Add / Edit Discount" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <VBox spacing="15.0">
                            <children>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Discount Name" textFill="#bdc3c7" />
                                                <TextField fx:id="nameField" promptText="e.g., Summer Special" style="-fx-background-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Discount Type" textFill="#bdc3c7" />
                                                <ComboBox fx:id="typeCombo" prefWidth="150.0" promptText="Select type" style="-fx-background-radius: 5;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Percentage / Amount" textFill="#bdc3c7" />
                                                <TextField fx:id="valueField" promptText="e.g., 15" style="-fx-background-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text=" " textFill="#bdc3c7" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <HBox alignment="CENTER_LEFT" spacing="15.0">
                                    <children>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="Start Date" textFill="#bdc3c7" />
                                                <DatePicker fx:id="startDatePicker" style="-fx-background-radius: 5;" />
                                            </children>
                                        </VBox>
                                        <VBox spacing="5.0" HBox.hgrow="ALWAYS">
                                            <children>
                                                <Label text="End Date" textFill="#bdc3c7" />
                                                <DatePicker fx:id="endDatePicker" style="-fx-background-radius: 5;" />
                                            </children>
                                        </VBox>
                                    </children>
                                </HBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Applicable Room Types" textFill="#bdc3c7" />
                                        <HBox spacing="20.0">
                                            <children>
                                                <CheckBox fx:id="singleCheck" text="Single" textFill="WHITE" />
                                                <CheckBox fx:id="doubleCheck" text="Double" textFill="WHITE" />
                                                <CheckBox fx:id="deluxeCheck" text="Deluxe" textFill="WHITE" />
                                                <CheckBox fx:id="penthouseCheck" text="Penthouse" textFill="WHITE" />
                                            </children>
                                        </HBox>
                                    </children>
                                </VBox>
                                <VBox spacing="5.0">
                                    <children>
                                        <Label text="Description (optional)" textFill="#bdc3c7" />
                                        <TextArea fx:id="descriptionArea" prefHeight="80.0" promptText="Additional details..." wrapText="true" />
                                    </children>
                                </VBox>
                                <HBox alignment="CENTER_RIGHT" spacing="15.0">
                                    <children>
                                        <Button mnemonicParsing="false" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-background-radius: 5; -fx-padding: 10 20;" text="Cancel" />
                                        <Button mnemonicParsing="false" onAction="#saveDiscount" style="-fx-background-color: #e2b96f; -fx-background-radius: 5; -fx-padding: 10 30;" text="Save Discount">
                                            <font>
                                                <Font name="System Bold" size="14.0" />
                                            </font>
                                        </Button>
                                    </children>
                                </HBox>
                            </children>
                        </VBox>
                        <Separator style="-fx-background-color: #7f8c8d;" />
                        <Label text="Current Seasonal Discounts" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <TableView fx:id="discountTable" prefHeight="250.0" prefWidth="1117.0" style="-fx-border-color: #e2b96f; -fx-background-color: #16213e; -fx-border-radius: 5;">
                            <columns>
                                <TableColumn fx:id="nameColumn" prefWidth="120.0" text="Name" />
                                <TableColumn fx:id="valueColumn" prefWidth="70.0" text="Value" />
                                <TableColumn fx:id="startColumn" prefWidth="100.0" text="Start Date" />
                                <TableColumn fx:id="endColumn" prefWidth="100.0" text="End Date" />
                                <TableColumn fx:id="roomsColumn" prefWidth="150.0" text="Room Types" />
                                <TableColumn fx:id="statusColumn" prefWidth="80.0" text="Status" />
                                <TableColumn fx:id="createdByColumn" prefWidth="120.0" text="Created By" />
                                <TableColumn fx:id="actionsColumn" prefWidth="120.0" text="Actions" />
                            </columns>
                            <placeholder>
                                <Label text="No discounts configured" textFill="#7f8c8d" />
                            </placeholder>
                        </TableView>
                        <HBox alignment="CENTER" spacing="15.0">
                            <children>
                                <Button mnemonicParsing="false" style="-fx-background-color: #2d3748; -fx-background-radius: 20; -fx-padding: 10 30;" text="Prev" textFill="WHITE">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Button>
                                <Label text="Page 1 of 5" textFill="WHITE" />
                                <Button mnemonicParsing="false" style="-fx-background-color: #e2b96f; -fx-background-radius: 20; -fx-padding: 10 30;" text="Next">
                                    <font>
                                        <Font name="System Bold" size="15.0" />
                                    </font>
                                </Button>
                            </children>
                        </HBox>
                    </children>
                </VBox>
            </children>
        </VBox>
    </center>
</BorderPane>
