<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskAddon">
    <top>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
                    <children>
                        <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets left="550.0" right="15.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Pane prefHeight="2" style="-fx-background-color: #e2b96f;" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #1a1a2e;">
            <children>
                <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;" text="Enhance your stay!" />
            <Label text="Extra ammenities to your stay at Hotel Transilvania" textFill="#e2b96f">
               <font>
                  <Font size="24.0" />
               </font>
            </Label>
                <VBox alignment="CENTER_LEFT" maxWidth="600" spacing="15.0">
                    <children>
                        <CheckBox fx:id="wifiCheckBox" text="Wi-Fi – $10 per night" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font></CheckBox>
                        <CheckBox fx:id="breakfastCheckBox" text="Breakfast – $15 per person per night" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font></CheckBox>
                        <CheckBox fx:id="parkingCheckBox" text="Parking – $20 per night" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font></CheckBox>
                        <CheckBox fx:id="spaCheckBox" text="Spa – $50 per stay" textFill="WHITE">
                     <font>
                        <Font size="20.0" />
                     </font>
                  </CheckBox>
                    </children>
                </VBox>
                <Label text="Subtotal: $540 | Add-ons: $45 | Total: $585" textFill="#e2b96f">
               <font>
                  <Font name="System Bold" size="20.0" />
               </font></Label>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                  <Button mnemonicParsing="false" onAction="#onCancel" style="-fx-background-color: #c3c0c0; -fx-background-radius: 20; -fx-padding: 10 30;" text="Cancel">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
                        <Button mnemonicParsing="false" onAction="#onBack" style="-fx-background-color: #2d3748; -fx-background-radius: 20; -fx-padding: 10 30;" text="Back" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#onNext" style="-fx-background-color: #e2b96f; -fx-background-radius: 20; -fx-padding: 10 30;" text="Next" textFill="#1a1a2e">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox>
            <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
                <children>
                    <Label text="Step 6 of 7" textFill="#b0b8cc">
                  <font>
                     <Font size="16.0" />
                  </font></Label>
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
