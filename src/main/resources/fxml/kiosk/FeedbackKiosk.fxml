<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="900.0" maxWidth="1400.0" minHeight="900.0" minWidth="1400.0" style="-fx-background-color: #16213e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskFeedback">
    <center>
        <VBox alignment="TOP_CENTER" maxWidth="1001.0" prefHeight="900.0" prefWidth="1001.0" spacing="20.0" style="-fx-background-color: #1a1a2e; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 40;">
            <children>
                <Label text="We Value Your Feedback!" textFill="WHITE">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <VBox spacing="5.0">
                    <children>
                        <Label text="Enter Your Phone Number Below" textFill="WHITE">
                            <font>
                                <Font size="14.0" />
                            </font>
                        </Label>
                        <TextField fx:id="phoneField" prefHeight="40.0" promptText="123-456-7890" style="-fx-background-radius: 10; -fx-border-color: #b0bec5; -fx-border-radius: 10;" />
                    </children>
                </VBox>
                <Separator style="-fx-background-color: #e0e0e0;" />
                <VBox spacing="10.0">
                    <children>
                        <Label text="How was your stay?" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                     <VBox.margin>
                        <Insets left="370.0" />
                     </VBox.margin>
                        </Label>
                        <HBox alignment="CENTER" spacing="10.0">
                            <children>
                                <Button fx:id="star1" mnemonicParsing="false" onAction="#onStar1" style="-fx-background-color: transparent;" text="★" textFill="#f1c40f">
                           <font>
                              <Font size="24.0" />
                           </font></Button>
                                <Button fx:id="star2" mnemonicParsing="false" onAction="#onStar2" style="-fx-background-color: transparent;" text="★" textFill="#f1c40f">
                           <font>
                              <Font size="24.0" />
                           </font></Button>
                                <Button fx:id="star3" mnemonicParsing="false" onAction="#onStar3" style="-fx-background-color: transparent;" text="★" textFill="#f1c40f">
                           <font>
                              <Font size="24.0" />
                           </font></Button>
                                <Button fx:id="star4" mnemonicParsing="false" onAction="#onStar4" style="-fx-background-color: transparent;" text="★" textFill="#f1c40f">
                           <font>
                              <Font size="24.0" />
                           </font></Button>
                                <Button fx:id="star5" mnemonicParsing="false" onAction="#onStar5" style="-fx-background-color: transparent;" text="★" textFill="#f1c40f">
                           <HBox.margin>
                              <Insets right="50.0" />
                           </HBox.margin>
                           <font>
                              <Font size="24.0" />
                           </font></Button>
                            </children>
                        </HBox>
                  <Slider fx:id="ratingSlider" maxWidth="300.0" minWidth="100.0" prefHeight="14.0" prefWidth="280.0">
                     <VBox.margin>
                        <Insets left="290.0" />
                     </VBox.margin>
                  </Slider>
                        <Label fx:id="Stars" text="0 Stars" textFill="#7f8c8d">
                            <font>
                                <Font size="14.0" />
                            </font>
                     <VBox.margin>
                        <Insets left="420.0" />
                     </VBox.margin>
                        </Label>
                    </children>
                </VBox>

                <Separator style="-fx-background-color: #e0e0e0;" />
                <HBox alignment="CENTER" spacing="30.0">
                    <children>
                        <Label text="Would you visit us again?" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <HBox spacing="20.0">
                            <children>
                                <RadioButton text="Yes">
                                    <toggleGroup>
                                        <ToggleGroup fx:id="visitGroup" />
                                    </toggleGroup>
                                </RadioButton>
                                <RadioButton text="No" toggleGroup="$visitGroup" />
                            </children>
                        </HBox>
                    </children>
                </HBox>

                <Separator style="-fx-background-color: #e0e0e0;" />
                <VBox spacing="10.0">
                    <children>
                        <Label text="How can we improve?" textFill="WHITE">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <TextArea fx:id="commentsArea" prefHeight="100.0" promptText="Tell us what you think..." wrapText="true" />
                        <Label fx:id="charCountLabel" alignment="CENTER_RIGHT" text="0/500 characters" textFill="#7f8c8d" />
                    </children>
                </VBox>

                <Separator style="-fx-background-color: #e0e0e0;" />
                <Label text="Thank you! We appreciate your feedback" textFill="#b29758">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onSkip" style="-fx-background-color: #2d3748; -fx-background-radius: 10; -fx-padding: 10 40;" text="Skip" textFill="WHITE">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Button>
                        <Button mnemonicParsing="false" onAction="#onSubmit" style="-fx-background-color: #e2b96f; -fx-background-radius: 10; -fx-padding: 10 40;" text="Submit">
                            <font>
                                <Font name="System Bold" size="15.0" />
                            </font>
                        </Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
               <children>
                  <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets left="550.0" right="15.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
            <Pane prefHeight="2" style="-fx-background-color: #e2b96f;" />
         </children>
      </VBox>
   </top>
   <bottom>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
               <children>
                  <Label textFill="#b0b8cc">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </bottom>
</BorderPane>
