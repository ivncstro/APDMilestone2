<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="-Infinity" maxWidth="-Infinity" minHeight="-Infinity" minWidth="-Infinity" prefHeight="900.0" prefWidth="1400.0" style="-fx-background-color: #1a1a2e;" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskConfirmation">
    <center>
        <VBox alignment="TOP_CENTER" maxWidth="600.0" spacing="20.0" style="-fx-background-color: #16213e; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.1), 10, 0, 0, 5); -fx-padding: 40;">
            <children>
                <Label text="✓ Reservation Confirmed!" textFill="#27ae60">
                    <font>
                        <Font name="System Bold" size="28.0" />
                    </font>
                </Label>
                <Label text="Thank you for choosing Hotel Transilvania." textFill="#e2b96f">
                    <font>
                        <Font size="16.0" />
                    </font>
                </Label>
                <Separator style="-fx-background-color: #e0e0e0;" />
                <VBox spacing="15.0" style="-fx-background-color: #16213e; -fx-border-color: #e2b96f; -fx-background-radius: 10; -fx-padding: 20;">
                    <children>
                        <Label text="Reservation Summary" textFill="#e2b96f">
                            <font>
                                <Font name="System Bold" size="18.0" />
                            </font>
                        </Label>
                        <GridPane hgap="15.0" vgap="10.0">
                            <columnConstraints>
                                <ColumnConstraints halignment="RIGHT" maxWidth="150.0" minWidth="120.0" prefWidth="120.0" />
                                <ColumnConstraints hgrow="ALWAYS" maxWidth="300.0" minWidth="200.0" />
                            </columnConstraints>
                            <rowConstraints>
                                <RowConstraints />
                                <RowConstraints />
                        <RowConstraints minHeight="10.0" />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                                <RowConstraints />
                            </rowConstraints>
                            <Label text="Confirmation #:" textFill="#7f8c8d" GridPane.rowIndex="0" />
                            <Label fx:id="confirmationCodeLabel" style="-fx-font-weight: bold;" text="TRV-123456" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                            <Label text="Guest:" textFill="#7f8c8d" GridPane.rowIndex="1" />
                            <Label fx:id="guestNameLabel" text="John Smith" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                            <Label text="Check-in:" textFill="#7f8c8d" GridPane.rowIndex="3" />
                            <Label fx:id="checkInLabel" text="2025-06-10" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                            <Label text="Check-out:" textFill="#7f8c8d" GridPane.rowIndex="4" />
                            <Label fx:id="checkOutLabel" text="2025-06-15" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                            <Label text="Room:" textFill="#7f8c8d" GridPane.rowIndex="5" />
                            <Label fx:id="roomLabel" text="2 x Double Room" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                            <Label text="Add-ons:" textFill="#7f8c8d" GridPane.rowIndex="6" />
                            <Label fx:id="addonsLabel" text="Wi-Fi, Breakfast" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                     <Label text="Email:" textFill="#7f8c8d" GridPane.rowIndex="2" />
                     <Label fx:id="emailLabel" text="example@email.com" textFill="#e2b96f" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        </GridPane>
                        <Separator style="-fx-background-color: #e0e0e0;" />
                        <HBox alignment="CENTER_RIGHT" spacing="10.0">
                            <children>
                                <Label style="-fx-font-weight: bold;" text="Total:" textFill="#e2b96f">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                                <Label fx:id="totalLabel" style="-fx-font-weight: bold;" text="\$0.00" textFill="#e2b96f">
                                    <font>
                                        <Font size="18.0" />
                                    </font>
                                </Label>
                            </children>
                        </HBox>
                    </children>
                </VBox>
                <VBox spacing="5.0" style="-fx-background-color: #e8f4fd; -fx-background-radius: 10; -fx-padding: 15;">
                    <children>
                        <Label style="-fx-font-weight: bold;" text="ℹ️ Billing at Front Desk" textFill="#2c3e50">
                            <font>
                                <Font size="16.0" />
                            </font>
                        </Label>
                        <Label prefHeight="60.0" prefWidth="490.0" text="Please proceed to the front desk of Hotel Transilvania to complete your payment and check-in. Your room is reserved, and payment will be handled upon arrival at the front desk.                   " textFill="#2c3e50" wrapText="true" />
                    </children>
                </VBox>
                <Button mnemonicParsing="false" onAction="#onDone" style="-fx-background-color: #4a6fa5; -fx-text-fill: white; -fx-background-radius: 10; -fx-padding: 12 40;" text="Done">
                    <font>
                        <Font name="System Bold" size="16.0" />
                    </font>
                </Button>
                <Label text="We look forward to welcoming you!" textFill="#e2b96f" />
            </children>
        </VBox>
    </center>
   <bottom>
      <VBox BorderPane.alignment="CENTER">
          <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
          <children>
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
               <children>
                  <Label text="Step 7 of 7" textFill="#b0b8cc">
                     <font>
                        <Font size="16.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
         </children>
      </VBox>
   </bottom>
   <top>
      <VBox BorderPane.alignment="CENTER">
         <children>
            <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
               <children>
                  <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                     <HBox.margin>
                        <Insets left="550.0" right="15.0" />
                     </HBox.margin>
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                  </Label>
               </children>
            </HBox>
             <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
         </children>
      </VBox>
   </top>
</BorderPane>
