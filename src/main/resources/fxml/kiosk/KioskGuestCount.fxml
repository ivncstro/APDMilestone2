<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskGuest">
    <top>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
                    <children>
                        <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets left="550.0" right="15.0" />
                            </HBox.margin>
                     <font>
                        <Font name="System Bold" size="24.0" />
                     </font>
                        </Label>
                    </children>
                </HBox>
                <Pane prefHeight="2" style="-fx-background-color: #e2b96f;" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #1a1a2e;">
            <children>
                <Label style="-fx-font-size: 36px; -fx-font-weight: bold; -fx-text-fill: white;" text="How many guests staying?" />
                <GridPane alignment="CENTER" hgap="30.0" vgap="15.0">
                    <children>
                        <Label style="-fx-text-fill: #b0b8cc;" text="Adults:" GridPane.columnIndex="0" GridPane.rowIndex="0">
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font></Label>
                        <Spinner fx:id="adultsSpinner" editable="true" initialValue="2" max="10" min="1" prefWidth="120" style="-fx-background-color: #2d3748; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="0" />
                        <Label style="-fx-text-fill: #b0b8cc;" text="Children:" GridPane.columnIndex="0" GridPane.rowIndex="1">
                     <font>
                        <Font name="System Bold" size="23.0" />
                     </font>
                     <GridPane.margin>
                        <Insets />
                     </GridPane.margin></Label>
                        <Spinner fx:id="childrenSpinner" editable="true" initialValue="0" max="10" min="0" prefWidth="120" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-font-size: 16px;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                    </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
                </GridPane>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                        <Button mnemonicParsing="false" onAction="#onBack" prefHeight="50.0" prefWidth="118.0" style="-fx-background-color: #2d3748; -fx-background-radius: 20; -fx-padding: 10 30;" text="Back" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#onNext" prefHeight="48.0" prefWidth="120.0" scaleShape="false" style="-fx-background-color: #e2b96f; -fx-text-fill: #1a1a2e; -fx-background-radius: 20;" text="Next" wrapText="true" HBox.hgrow="NEVER">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font></Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox>
            <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
                <children>
                    <Label style="-fx-font-size: 16px; -fx-text-fill: #b0b8cc;" text="Step 3 of 8" />
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
