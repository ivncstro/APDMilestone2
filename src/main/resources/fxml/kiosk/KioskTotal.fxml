<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane maxHeight="900.0" prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskTotal">
    <top>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
                    <children>
                        <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets left="550.0" right="15.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Pane prefHeight="2" style="-fx-background-color: #e2b96f;" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="TOP_CENTER" spacing="25.0" style="-fx-background-color: #1a1a2e; -fx-padding: 40 0 0 0;">
            <children>
                <Label text="Your reservation summary" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font></Label>
                <VBox maxWidth="600" prefHeight="195.0" prefWidth="600.0" spacing="10.0" style="-fx-background-color: #16213e; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <children>
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;" text="Rooms" />
                  <TextArea fx:id="roomsSummaryArea" minHeight="120.0" prefHeight="120.0" prefWidth="200.0" promptText="Rooms selected" style="-fx-background-color: #c3c0c0;">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </TextArea>
                    </children>
                </VBox>
                <VBox maxHeight="210.0" maxWidth="600" minHeight="195.0" prefHeight="190.0" spacing="10.0" style="-fx-background-color: #16213e; -fx-background-radius: 15; -fx-padding: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);">
                    <children>
                        <Label style="-fx-text-fill: #e2b96f;" text="Add-ons">
                     <font>
                        <Font name="System Bold" size="20.0" />
                     </font>
                     <VBox.margin>
                        <Insets />
                     </VBox.margin></Label>
                  <TextArea fx:id="addonsSummaryArea" maxHeight="120.0" minHeight="120.0" prefHeight="120.0" prefWidth="560.0" promptText="Add-ons selected" style="-fx-background-color: #c3c0c0;">
                     <VBox.margin>
                        <Insets />
                     </VBox.margin>
                  </TextArea>
                    </children>
                </VBox>
                <GridPane alignment="CENTER" hgap="40.0" maxHeight="180.0" maxWidth="1002.0" minHeight="200.0" minWidth="200.0" prefHeight="180.0" prefWidth="1002.0" style="-fx-background-color: #16213e; -fx-background-radius: 20; -fx-effect: dropshadow(gaussian, rgba(0,0,0,0.3), 10, 0, 0, 5);" vgap="10.0">
                    <children>
                        <Label prefHeight="27.0" prefWidth="135.0" text="Room charges:" textFill="#b0b8cc" GridPane.columnIndex="4">
                     <font>
                        <Font size="18.0" />
                     </font>
                     <padding>
                        <Insets top="50.0" />
                     </padding></Label>
                        <Label fx:id="roomChargesLabel" prefHeight="27.0" prefWidth="132.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="\$0.00" GridPane.columnIndex="5">
                     <padding>
                        <Insets top="50.0" />
                     </padding></Label>
                        <Label text="Add-ons:" textFill="#b0b8cc" GridPane.columnIndex="4" GridPane.rowIndex="1">
                     <font>
                        <Font size="18.0" />
                     </font></Label>
                        <Label fx:id="addonsLabel" prefHeight="27.0" prefWidth="145.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="\$0.00" GridPane.columnIndex="5" GridPane.rowIndex="1" />
                        <Label prefHeight="27.0" prefWidth="68.0" text="Tax:" textFill="#b0b8cc" GridPane.columnIndex="4" GridPane.rowIndex="2">
                     <font>
                        <Font size="18.0" />
                     </font></Label>
                        <Label fx:id="taxLabel" prefHeight="27.0" prefWidth="140.0" style="-fx-font-size: 18px; -fx-font-weight: bold; -fx-text-fill: white;" text="\$0.00" GridPane.columnIndex="5" GridPane.rowIndex="2" />
                        <Separator GridPane.columnIndex="4" GridPane.columnSpan="2" GridPane.rowIndex="4" />
                        <Label style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;" text="Total:" GridPane.columnIndex="4" GridPane.rowIndex="5" />
                        <Label fx:id="totalLabel" prefHeight="30.0" prefWidth="131.0" style="-fx-font-size: 20px; -fx-font-weight: bold; -fx-text-fill: #e2b96f;" text="\$0.00" GridPane.columnIndex="5" GridPane.rowIndex="5" />
                  <Label minHeight="27.0" prefHeight="27.0" prefWidth="153.0" text="Loyalty Number: " textFill="#b0b8cc" GridPane.columnIndex="4" GridPane.rowIndex="3">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <Label fx:id="loyaltyNumberLabel" minHeight="27.0" prefHeight="27.0" prefWidth="153.0" text="TRV123456" textFill="#b0b8cc" GridPane.columnIndex="5" GridPane.rowIndex="3">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                    </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
               </rowConstraints>
               <VBox.margin>
                  <Insets />
               </VBox.margin>
                </GridPane>
                <HBox alignment="CENTER" spacing="20.0" style="-fx-padding: 10 0 40 0;">
                    <children>
                  <Button mnemonicParsing="false" onAction="#onCancel" style="-fx-background-color: #c3c0c0; -fx-background-radius: 20; -fx-padding: 10 30;" text="Cancel">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
                        <Button mnemonicParsing="false" onAction="#onBack" style="-fx-background-color: #2d3748; -fx-background-radius: 20; -fx-padding: 10 30;" text="Back" textFill="WHITE">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#onConfirm" style="-fx-background-color: #e2b96f; -fx-background-radius: 20; -fx-padding: 10 30;" text="Confirm" textFill="#1a1a2e">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox>
            <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
                <children>
                    <Label text="Step 7 of 7" textFill="#b0b8cc">
                  <font>
                     <Font size="16.0" />
                  </font></Label>
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
