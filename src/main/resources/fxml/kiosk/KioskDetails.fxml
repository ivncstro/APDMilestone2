<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.*?>
<?import javafx.scene.control.*?>
<?import javafx.scene.layout.*?>
<?import javafx.scene.text.*?>

<BorderPane prefHeight="900.0" prefWidth="1400.0" xmlns="http://javafx.com/javafx/17.0.12" xmlns:fx="http://javafx.com/fxml/1" fx:controller="com.transylvania.controller.KioskDetails">
    <top>
        <VBox>
            <children>
                <HBox alignment="CENTER_LEFT" spacing="10.0" style="-fx-background-color: #16213e; -fx-padding: 15 30;">
                    <children>
                        <Label text="🏨 Hotel Transilvania" textFill="#e2b96f" HBox.hgrow="ALWAYS">
                            <HBox.margin>
                                <Insets left="550.0" right="15.0" />
                            </HBox.margin>
                            <font>
                                <Font name="System Bold" size="24.0" />
                            </font>
                        </Label>
                    </children>
                </HBox>
                <Pane prefHeight="2" style="-fx-background-color: #e2b96f;" />
            </children>
        </VBox>
    </top>
    <center>
        <VBox alignment="CENTER" spacing="30.0" style="-fx-background-color: #1a1a2e;">
            <children>
                <Label text="Guest details" textFill="WHITE">
               <font>
                  <Font name="System Bold" size="36.0" />
               </font></Label>
                <GridPane alignment="CENTER" hgap="20.0" vgap="15.0">
                    <children>
                        <Label style="-fx-font-size: 18px;" text="Last name*:" textFill="#b0b8cc" GridPane.rowIndex="1" />
                        <TextField fx:id="guestName" prefWidth="300" promptText="Doe" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="1" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #b0b8cc;" text="Email*:" GridPane.rowIndex="2" />
                        <TextField fx:id="guestEmail" prefWidth="300" promptText="john@example.com" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="2" />
                        <Label style="-fx-font-size: 18px; -fx-text-fill: #b0b8cc;" text="Phone*:" textFill="#b0b8cc" GridPane.rowIndex="3">
                     <font>
                        <Font size="18.0" />
                     </font></Label>
                        <TextField fx:id="guestPhone" prefWidth="300" promptText="+1234567890" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="3" />
                  <Label text="Address:" textFill="#b0b8cc" GridPane.rowIndex="4">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <Label text="Country:" textFill="#b0b8cc" GridPane.rowIndex="5">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <Label text="City:" textFill="#b0b8cc" GridPane.rowIndex="6">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <TextField fx:id="guestAddress" prefWidth="300" promptText="Enter your address" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="4" />
                  <TextField fx:id="guestCountry" prefWidth="300" promptText="Enter your country" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="5" />
                  <TextField fx:id="guestCity" prefWidth="300" promptText="Enter your city" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" GridPane.rowIndex="6" />
                  <Label text="First  name*:" textFill="#b0b8cc">
                     <font>
                        <Font size="18.0" />
                     </font>
                  </Label>
                  <TextField fx:id="guestName1" prefWidth="300" promptText="John Doe" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-prompt-text-fill: #4a5568; -fx-font-size: 16px; -fx-background-radius: 10;" GridPane.columnIndex="1" />
                    </children>
               <columnConstraints>
                  <ColumnConstraints />
                  <ColumnConstraints />
               </columnConstraints>
               <rowConstraints>
                  <RowConstraints minHeight="10.0" prefHeight="30.0" />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" />
                  <RowConstraints minHeight="10.0" prefHeight="30.0" />
               </rowConstraints>
                </GridPane>
                <CheckBox fx:id="loyaltyEnroll" text="Enroll in loyalty program" textFill="WHITE">
               <font>
                  <Font size="16.0" />
               </font></CheckBox>
                <HBox alignment="CENTER" spacing="20.0">
                    <children>
                  <Button mnemonicParsing="false" onAction="#onCancel" style="-fx-background-color: #c3c0c0; -fx-background-radius: 20; -fx-padding: 10 30;" text="Cancel">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font>
                  </Button>
                        <Button mnemonicParsing="false" onAction="#onBack" style="-fx-background-color: #2d3748; -fx-text-fill: white; -fx-background-radius: 20; -fx-padding: 10 30;" text="Back">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                        <Button mnemonicParsing="false" onAction="#onNext" style="-fx-background-color: #e2b96f; -fx-background-radius: 20; -fx-padding: 10 30;" text="Next" textFill="#1a1a2e">
                     <font>
                        <Font name="System Bold" size="15.0" />
                     </font></Button>
                    </children>
                </HBox>
            </children>
        </VBox>
    </center>
    <bottom>
        <VBox>
            <Pane prefHeight="2.0" style="-fx-background-color: #e2b96f;" />
            <HBox alignment="CENTER" spacing="10.0" style="-fx-padding: 15; -fx-background-color: #16213e;">
                <children>
                    <Label text="Step 5 of 7" textFill="#b0b8cc">
                  <font>
                     <Font size="16.0" />
                  </font></Label>
                </children>
            </HBox>
        </VBox>
    </bottom>
</BorderPane>
